---
---

<section id="regalo" class="py-28 md:py-36 bg-cream-50 relative overflow-hidden">
  <!-- Subtle decorative background -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #5f704c 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="relative max-w-2xl mx-auto px-6 text-center">
    
    <!-- Header -->
    <div class="reveal mb-10">
      <p class="font-sans text-xs tracking-[0.3em] uppercase text-sage-400 mb-4">Un detalle</p>
      <h2 class="heading-display text-4xl md:text-5xl">Vuestro regalo</h2>
    </div>

    <!-- Decorative divider -->
    <div class="flex items-center justify-center gap-4 mb-12 reveal">
      <span class="w-12 h-px bg-sage-300/50"></span>
      <svg class="w-5 h-5 text-sage-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
      </svg>
      <span class="w-12 h-px bg-sage-300/50"></span>
    </div>

    <!-- Message -->
    <div class="reveal mb-14">
      <p class="font-body text-lg md:text-xl text-sage-600 leading-relaxed max-w-lg mx-auto mb-6">
        Lo que más nos importa es que nos acompañéis en este día tan especial. 
        Pero si queréis tener un detalle con nosotros, podéis contribuir 
        a nuestra luna de miel.
      </p>
      <p class="font-body text-lg text-sage-500 leading-relaxed max-w-lg mx-auto">
        ¡Cualquier gesto nos hará muchísima ilusión!
      </p>
    </div>

    <!-- Account card -->
    <div class="reveal">
      <div class="bg-white rounded-xl p-8 md:p-10 border border-sage-100 
                  shadow-[0_4px_30px_rgba(107,128,80,0.06)] max-w-md mx-auto">
        
        <!-- Icon -->
        <div class="w-12 h-12 mx-auto mb-6 rounded-full bg-sage-50 flex items-center justify-center">
          <svg class="w-5 h-5 text-sage-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
          </svg>
        </div>

        <p class="font-sans text-[10px] tracking-[0.2em] uppercase text-sage-400 mb-5">Número de cuenta</p>
        
        <!-- IBAN with copy -->
        <div class="bg-sage-50/60 rounded-lg px-5 py-4 mb-4 flex items-center justify-center gap-3
                    border border-sage-100/80">
          <p id="iban" class="font-sans text-sm md:text-base text-sage-700 tracking-[0.08em] font-medium select-all">
            ES12 3456 7890 1234 5678 9012
          </p>
          <button 
            id="copy-iban" 
            class="p-2 -mr-1 rounded-lg hover:bg-sage-100 transition-all duration-300 group shrink-0"
            aria-label="Copiar IBAN"
          >
            <!-- Copy icon -->
            <svg id="copy-icon" class="w-4 h-4 text-sage-400 group-hover:text-sage-600 transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5a3.375 3.375 0 00-3.375-3.375H9.75" />
            </svg>
            <!-- Check icon (shown after copy) -->
            <svg id="check-icon" class="w-4 h-4 text-sage-600 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </button>
        </div>

        <p id="copy-feedback" class="font-sans text-xs text-sage-500 mb-5 h-5 opacity-0 transition-opacity duration-300">
          Copiado al portapapeles
        </p>

        <div class="w-10 h-px bg-sage-200 mx-auto mb-5"></div>

        <p class="font-body text-sm text-sage-400">
          Titular: Roberto García & Marina López
        </p>
      </div>
    </div>

    <!-- Thanks note at bottom -->
    <div class="reveal mt-14">
      <p class="font-display text-xl md:text-2xl text-sage-500 italic">
        Os damos las gracias de corazón
      </p>
    </div>

  </div>
</section>

<script>
  const copyBtn = document.getElementById('copy-iban');
  const copyIcon = document.getElementById('copy-icon');
  const checkIcon = document.getElementById('check-icon');
  const feedback = document.getElementById('copy-feedback');

  copyBtn?.addEventListener('click', async () => {
    const iban = document.getElementById('iban')?.textContent?.trim();
    if (!iban) return;

    try {
      await navigator.clipboard.writeText(iban.replace(/\s/g, ''));
      
      // Swap icons
      copyIcon?.classList.add('hidden');
      checkIcon?.classList.remove('hidden');
      
      // Show feedback
      feedback?.classList.remove('opacity-0');
      feedback?.classList.add('opacity-100');
      
      setTimeout(() => {
        copyIcon?.classList.remove('hidden');
        checkIcon?.classList.add('hidden');
        feedback?.classList.remove('opacity-100');
        feedback?.classList.add('opacity-0');
      }, 2500);
    } catch {
      // Fallback: select the text
      const el = document.getElementById('iban');
      if (el) {
        const range = document.createRange();
        range.selectNodeContents(el);
        const sel = window.getSelection();
        sel?.removeAllRanges();
        sel?.addRange(range);
      }
    }
  });
</script>