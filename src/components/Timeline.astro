---
const events = [
  {
    time: '12:00',
    title: 'Ceremonia',
    subtitle: 'Iglesia de Santo Tomé',
    description: 'La ceremonia religiosa tendrá lugar en la preciosa Iglesia de Santo Tomé, en pleno casco histórico de Toledo.',
    image: 'https://images.unsplash.com/photo-1543002588-bfa74002ed7e?w=800&q=80',
    detailsId: 'iglesia-details',
    address: 'Plaza del Conde, 4, 45002 Toledo',
    mapLink: 'https://maps.google.com/?q=Iglesia+de+Santo+Tomé+Toledo',
    icon: 'church',
  },
  {
    time: '14:00',
    title: 'Celebración',
    subtitle: 'Cigarral de las Mercedes',
    description: 'El banquete y la fiesta se celebrarán en el Cigarral de las Mercedes, con unas vistas espectaculares de Toledo.',
    image: 'https://images.unsplash.com/photo-1464366400600-7168b8af9bc3?w=800&q=80',
    detailsId: 'cigarral-details',
    address: 'Carretera de Piedrabuena, km 1, 45004 Toledo',
    mapLink: 'https://maps.google.com/?q=Cigarral+de+las+Mercedes+Toledo',
    icon: 'celebration',
  },
  {
    time: '00:30',
    title: 'Autobús de vuelta',
    subtitle: 'Regreso al centro',
    description: 'Autobuses de vuelta al centro de Toledo. Os dejarán en la Plaza de Zocodover.',
    image: 'https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?w=800&q=80',
    detailsId: 'bus-details',
    address: 'Salida desde el Cigarral de las Mercedes',
    mapLink: '',
    icon: 'bus',
  },
];
---

<section id="celebracion" class="py-20 md:py-28 bg-cream-50">
  <!-- Header -->
  <div class="text-center mb-14 px-6 reveal">
    <p class="font-sans text-xs tracking-[0.3em] uppercase text-sage-400 mb-4">El plan</p>
    <h2 class="heading-display text-4xl md:text-5xl">Cómo será el día</h2>
  </div>

  <!-- Timeline cards — centered, compact -->
  <div class="relative max-w-xl mx-auto px-6">
    
    <!-- Vertical connecting line -->
    <div class="absolute left-1/2 top-0 bottom-0 w-px bg-sage-200/70 -translate-x-1/2 hidden md:block"></div>

    {events.map((event, index) => (
      <div class={`reveal relative ${index < events.length - 1 ? 'mb-8' : ''}`}>
        
        <!-- Timeline dot (desktop) -->
        <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 -top-4 z-20
                    w-10 h-10 rounded-full bg-cream-50 border-2 border-sage-300 
                    items-center justify-center shadow-sm">
          {event.icon === 'church' && (
            <svg class="w-4.5 h-4.5 text-sage-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 2v4m0 0l3 3H9l3-3zM6 9v11h12V9M4 20h16M9 14h.01M15 14h.01M12 9v5" />
            </svg>
          )}
          {event.icon === 'celebration' && (
            <svg class="w-4.5 h-4.5 text-sage-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
            </svg>
          )}
          {event.icon === 'bus' && (
            <svg class="w-4.5 h-4.5 text-sage-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 17h.01M16 17h.01M6 3h12a2 2 0 012 2v10a2 2 0 01-2 2H6a2 2 0 01-2-2V5a2 2 0 012-2zm0 0V2m12 1V2M4 10h16M8 17a1 1 0 11-2 0 1 1 0 012 0zm10 0a1 1 0 11-2 0 1 1 0 012 0zM5 20h3m8 0h3" />
            </svg>
          )}
        </div>

        <!-- Card -->
        <div class="group bg-white rounded-lg overflow-hidden shadow-[0_4px_30px_rgba(107,128,80,0.08)] 
                    border border-sage-100/60 hover:shadow-[0_8px_40px_rgba(107,128,80,0.12)] 
                    transition-shadow duration-500 md:mt-6">
          
          <!-- Big image with overlay info -->
          <div class="relative aspect-[16/9] overflow-hidden">
            <img
              src={event.image}
              alt={event.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
            <!-- Gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-sage-900/70 via-sage-900/20 to-transparent"></div>
            
            <!-- Time + Title on image -->
            <div class="absolute bottom-0 left-0 right-0 p-5 md:p-7">
              <span class="inline-block font-sans text-[10px] tracking-[0.25em] uppercase text-white/70 
                           bg-white/15 backdrop-blur-sm px-3 py-1 rounded-full mb-3 border border-white/10">
                {event.time}h
              </span>
              <h3 class="font-display text-2xl md:text-3xl text-white leading-tight">{event.title}</h3>
              <p class="font-body text-base text-white/80 italic">{event.subtitle}</p>
            </div>
          </div>

          <!-- Content body -->
          <div class="p-5 md:p-7">
            <p class="font-body text-sage-600 leading-relaxed mb-5">{event.description}</p>

            <!-- Quick info row -->
            <div class="flex flex-wrap items-center gap-3 mb-4">
              {event.mapLink && (
                <a
                  href={event.mapLink}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 text-sage-600 bg-sage-50 hover:bg-sage-100 
                         px-4 py-2 rounded-full font-sans text-xs tracking-wide transition-colors duration-300"
                >
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  Cómo llegar
                </a>
              )}
              <button
                class="toggle-details inline-flex items-center gap-2 text-sage-500 hover:text-sage-700 
                       px-4 py-2 rounded-full font-sans text-xs tracking-wide border border-sage-200 
                       hover:border-sage-300 transition-all duration-300"
                data-target={event.detailsId}
              >
                <svg class="w-3.5 h-3.5 transition-transform duration-300 details-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
                Más info
              </button>
            </div>

            <!-- Expandable details -->
            <div id={event.detailsId} class="details-panel" style="max-height: 0; overflow: hidden; transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease; opacity: 0;">
              <div class="pt-4 border-t border-sage-100 space-y-4">
                
                <!-- Address -->
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-full bg-sage-50 flex items-center justify-center shrink-0 mt-0.5">
                    <svg class="w-4 h-4 text-sage-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-sans text-[10px] tracking-[0.15em] uppercase text-sage-400 mb-0.5">Dirección</p>
                    <p class="font-body text-sage-700 text-[15px]">{event.address}</p>
                  </div>
                </div>

                {/* Parking info for church */}
                {event.detailsId === 'iglesia-details' && (
                  <div class="bg-sage-50/50 rounded-lg p-4">
                    <div class="flex items-center gap-2 mb-3">
                      <div class="w-6 h-6 rounded-full bg-white flex items-center justify-center">
                        <svg class="w-3 h-3 text-sage-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M8 4h4a4 4 0 010 8H8V4zm0 8v8" />
                        </svg>
                      </div>
                      <p class="font-sans text-[10px] tracking-[0.15em] uppercase text-sage-500">Aparcamiento cercano</p>
                    </div>
                    <div class="space-y-2 text-[14px]">
                      <div class="flex items-center gap-2 font-body text-sage-600">
                        <span class="w-1.5 h-1.5 rounded-full bg-sage-300 shrink-0"></span>
                        Parking Alcázar — C/ de la Unión, s/n <span class="text-sage-400">(5 min)</span>
                      </div>
                      <div class="flex items-center gap-2 font-body text-sage-600">
                        <span class="w-1.5 h-1.5 rounded-full bg-sage-300 shrink-0"></span>
                        Parking Miradero — Paseo de Recaredo <span class="text-sage-400">(7 min)</span>
                      </div>
                      <div class="flex items-center gap-2 font-body text-sage-600">
                        <span class="w-1.5 h-1.5 rounded-full bg-sage-300 shrink-0"></span>
                        Aparcamiento gratuito — Paseo de la Rosa <span class="text-sage-400">(10 min)</span>
                      </div>
                    </div>
                  </div>
                )}

                {/* Bus info */}
                {event.detailsId === 'bus-details' && (
                  <div class="bg-sage-50/50 rounded-lg p-4 space-y-3">
                    <div class="flex items-start gap-3">
                      <div class="w-7 h-7 rounded-full bg-white flex items-center justify-center shrink-0 shadow-sm">
                        <svg class="w-3.5 h-3.5 text-sage-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18" />
                        </svg>
                      </div>
                      <div>
                        <p class="font-sans text-[10px] tracking-[0.15em] uppercase text-sage-400 mb-1">Ida al Cigarral</p>
                        <p class="font-body text-sage-700 text-[14px]">
                          Recogida en <strong>Plaza de Zocodover</strong> a las <strong>13:15h</strong>
                        </p>
                      </div>
                    </div>
                    <div class="w-full h-px bg-sage-200/50"></div>
                    <div class="flex items-start gap-3">
                      <div class="w-7 h-7 rounded-full bg-white flex items-center justify-center shrink-0 shadow-sm">
                        <svg class="w-3.5 h-3.5 text-sage-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
                        </svg>
                      </div>
                      <div>
                        <p class="font-sans text-[10px] tracking-[0.15em] uppercase text-sage-400 mb-1">Vuelta al centro</p>
                        <p class="font-body text-sage-700 text-[14px]">
                          Salida del Cigarral entre las <strong>00:30h y 01:00h</strong> a Plaza de Zocodover
                        </p>
                      </div>
                    </div>
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  document.querySelectorAll('.toggle-details').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const panel = document.getElementById(targetId!) as HTMLElement;
      const arrow = btn.querySelector('.details-arrow');
      if (!panel) return;

      const isCollapsed = panel.style.maxHeight === '0px' || panel.style.maxHeight === '';

      if (isCollapsed) {
        // Expand: measure real height, then animate
        panel.style.maxHeight = panel.scrollHeight + 'px';
        panel.style.opacity = '1';
        arrow?.classList.add('rotate-180');
        const textNode = btn.childNodes[btn.childNodes.length - 1];
        if (textNode) textNode.textContent = ' Menos info';

        // After transition, allow content to grow if needed
        panel.addEventListener('transitionend', function handler() {
          if (panel.style.opacity === '1') {
            panel.style.maxHeight = 'none';
          }
          panel.removeEventListener('transitionend', handler);
        });
      } else {
        // Collapse: set explicit height first, then animate to 0
        panel.style.maxHeight = panel.scrollHeight + 'px';
        // Force reflow
        panel.offsetHeight;
        panel.style.maxHeight = '0px';
        panel.style.opacity = '0';
        arrow?.classList.remove('rotate-180');
        const textNode = btn.childNodes[btn.childNodes.length - 1];
        if (textNode) textNode.textContent = ' Más info';
      }
    });
  });
</script>