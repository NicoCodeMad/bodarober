---
---

<section id="formulario" class="py-20 md:py-28 bg-warm-100/50">
  <div class="max-w-lg mx-auto px-6">
    <div class="text-center mb-12 reveal">
      <p class="font-sans text-xs tracking-[0.3em] uppercase text-sage-400 mb-4">Confirma tu asistencia</p>
      <h2 class="heading-display text-4xl md:text-5xl mb-4">¿Vienes a celebrarlo?</h2>
      <p class="font-body text-sage-500 max-w-md mx-auto leading-relaxed">
        Por favor, confirma antes del <strong class="text-sage-700">15 de julio de 2026</strong>. 
        Necesitamos algunos detalles para que todo salga perfecto.
      </p>
    </div>

    <div class="reveal">
      <!-- 
        TODO: Conectar con Google Forms.
        1) Embed iframe  2) POST a action URL  3) Apps Script endpoint
      -->
      <form id="rsvp-form" data-connected="false">
        
        <!-- Step 1: Nombre -->
        <div class="mb-7">
          <label for="nombre" class="block font-sans text-[11px] tracking-[0.15em] uppercase text-sage-500 mb-2.5">
            Nombre completo
          </label>
          <input 
            type="text" 
            id="nombre" 
            name="nombre" 
            placeholder="Tu nombre y apellidos" 
            required
            class="w-full bg-white border border-sage-200 rounded-lg px-5 py-3.5 
                   font-body text-sage-800 text-base
                   placeholder:text-sage-300
                   focus:outline-none focus:border-sage-400 focus:ring-2 focus:ring-sage-200/50
                   transition-all duration-300"
          />
        </div>

        <!-- Step 2: Asistencia — card style -->
        <div class="mb-7">
          <label class="block font-sans text-[11px] tracking-[0.15em] uppercase text-sage-500 mb-3">
            ¿Asistirás a la boda?
          </label>
          <div class="grid grid-cols-2 gap-3">
            <label class="rsvp-option relative cursor-pointer">
              <input type="radio" name="asistencia" value="si" required class="sr-only rsvp-radio" />
              <div class="rsvp-card flex flex-col items-center gap-2 p-5 rounded-lg border-2 border-sage-200 bg-white
                          hover:border-sage-300 transition-all duration-300">
                <svg class="w-6 h-6 text-sage-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span class="font-body text-sage-700 text-sm text-center">¡Allí estaré!</span>
              </div>
            </label>
            <label class="rsvp-option relative cursor-pointer">
              <input type="radio" name="asistencia" value="no" class="sr-only rsvp-radio" />
              <div class="rsvp-card flex flex-col items-center gap-2 p-5 rounded-lg border-2 border-sage-200 bg-white
                          hover:border-sage-300 transition-all duration-300">
                <svg class="w-6 h-6 text-sage-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 16.318A4.486 4.486 0 0012.016 15a4.486 4.486 0 00-3.198 1.318M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z" />
                </svg>
                <span class="font-body text-sage-700 text-sm text-center">No puedo ir</span>
              </div>
            </label>
          </div>
        </div>

        <!-- Step 3: Campos condicionales (si asiste) — smooth expand -->
        <div id="attending-fields" style="max-height: 0; overflow: hidden; opacity: 0; transition: max-height 0.6s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;">
          
          <!-- Acompañantes -->
          <div class="mb-7">
            <label for="acompanantes" class="block font-sans text-[11px] tracking-[0.15em] uppercase text-sage-500 mb-2.5">
              ¿Cuántos sois en total? (incluyéndote)
            </label>
            <div class="relative">
              <select id="acompanantes" name="acompanantes" 
                class="w-full bg-white border border-sage-200 rounded-lg px-5 py-3.5 
                       font-body text-sage-800 text-base appearance-none
                       focus:outline-none focus:border-sage-400 focus:ring-2 focus:ring-sage-200/50
                       transition-all duration-300">
                <option value="1">1 persona</option>
                <option value="2" selected>2 personas</option>
                <option value="3">3 personas</option>
                <option value="4">4 personas</option>
                <option value="5">5 o más personas</option>
              </select>
              <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-sage-400 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>

          <!-- Alergias -->
          <div class="mb-7">
            <label for="alergias" class="block font-sans text-[11px] tracking-[0.15em] uppercase text-sage-500 mb-2.5">
              Alergias o intolerancias alimentarias
            </label>
            <input 
              type="text" 
              id="alergias" 
              name="alergias" 
              placeholder="Ej: celíaco, alergia a frutos secos..." 
              class="w-full bg-white border border-sage-200 rounded-lg px-5 py-3.5 
                     font-body text-sage-800 text-base
                     placeholder:text-sage-300
                     focus:outline-none focus:border-sage-400 focus:ring-2 focus:ring-sage-200/50
                     transition-all duration-300"
            />
          </div>

          <!-- Bus — card options -->
          <div class="mb-7">
            <label class="block font-sans text-[11px] tracking-[0.15em] uppercase text-sage-500 mb-3">
              ¿Necesitáis autobús?
            </label>
            <div class="grid grid-cols-2 gap-3">
              <label class="rsvp-option relative cursor-pointer">
                <input type="radio" name="bus" value="ida-vuelta" class="sr-only rsvp-radio" />
                <div class="rsvp-card flex items-center gap-2.5 p-3.5 rounded-lg border-2 border-sage-200 bg-white
                            hover:border-sage-300 transition-all duration-300">
                  <svg class="w-4 h-4 text-sage-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                  </svg>
                  <span class="font-body text-sage-700 text-sm">Ida y vuelta</span>
                </div>
              </label>
              <label class="rsvp-option relative cursor-pointer">
                <input type="radio" name="bus" value="solo-ida" class="sr-only rsvp-radio" />
                <div class="rsvp-card flex items-center gap-2.5 p-3.5 rounded-lg border-2 border-sage-200 bg-white
                            hover:border-sage-300 transition-all duration-300">
                  <svg class="w-4 h-4 text-sage-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18" />
                  </svg>
                  <span class="font-body text-sage-700 text-sm">Solo ida</span>
                </div>
              </label>
              <label class="rsvp-option relative cursor-pointer">
                <input type="radio" name="bus" value="solo-vuelta" class="sr-only rsvp-radio" />
                <div class="rsvp-card flex items-center gap-2.5 p-3.5 rounded-lg border-2 border-sage-200 bg-white
                            hover:border-sage-300 transition-all duration-300">
                  <svg class="w-4 h-4 text-sage-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
                  </svg>
                  <span class="font-body text-sage-700 text-sm">Solo vuelta</span>
                </div>
              </label>
              <label class="rsvp-option relative cursor-pointer">
                <input type="radio" name="bus" value="no" class="sr-only rsvp-radio" />
                <div class="rsvp-card flex items-center gap-2.5 p-3.5 rounded-lg border-2 border-sage-200 bg-white
                            hover:border-sage-300 transition-all duration-300">
                  <svg class="w-4 h-4 text-sage-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                  </svg>
                  <span class="font-body text-sage-700 text-sm">No necesito</span>
                </div>
              </label>
            </div>
          </div>

          <!-- Canción -->
          <div class="mb-7">
            <label for="cancion" class="block font-sans text-[11px] tracking-[0.15em] uppercase text-sage-500 mb-2.5">
              Una canción que no puede faltar en la fiesta
            </label>
            <div class="relative">
              <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-sage-300 pointer-events-none" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 11-.99-3.467l2.31-.66a2.25 2.25 0 001.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 01-.99-3.467l2.31-.66A2.25 2.25 0 009 15.553z" />
              </svg>
              <input 
                type="text" 
                id="cancion" 
                name="cancion" 
                placeholder="Ej: Vivir mi vida — Marc Anthony" 
                class="w-full bg-white border border-sage-200 rounded-lg pl-11 pr-5 py-3.5 
                       font-body text-sage-800 text-base
                       placeholder:text-sage-300
                       focus:outline-none focus:border-sage-400 focus:ring-2 focus:ring-sage-200/50
                       transition-all duration-300"
              />
            </div>
          </div>
        </div>

        <!-- Mensaje (siempre visible) -->
        <div class="mb-8">
          <label for="mensaje" class="block font-sans text-[11px] tracking-[0.15em] uppercase text-sage-500 mb-2.5">
            ¿Algo que quieras decirnos?
          </label>
          <textarea 
            id="mensaje" 
            name="mensaje" 
            rows="3" 
            placeholder="Un mensajito para los novios..." 
            class="w-full bg-white border border-sage-200 rounded-lg px-5 py-3.5 
                   font-body text-sage-800 text-base resize-none
                   placeholder:text-sage-300
                   focus:outline-none focus:border-sage-400 focus:ring-2 focus:ring-sage-200/50
                   transition-all duration-300"
          ></textarea>
        </div>

        <!-- Submit -->
        <button type="submit" 
          class="w-full bg-sage-600 text-cream-50 py-4 rounded-lg
                 font-sans text-sm tracking-[0.15em] uppercase
                 hover:bg-sage-700 active:scale-[0.98]
                 transition-all duration-300
                 focus:outline-none focus:ring-2 focus:ring-sage-400 focus:ring-offset-2">
          Enviar confirmación
        </button>
      </form>

      <!-- Success message -->
      <div id="form-success" class="hidden text-center py-14">
        <div class="w-16 h-16 mx-auto mb-5 rounded-full bg-sage-100 flex items-center justify-center">
          <svg class="w-8 h-8 text-sage-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <h3 class="heading-display text-2xl mb-2">¡Gracias!</h3>
        <p class="font-body text-sage-500">Hemos recibido tu confirmación.<br/>¡Nos vemos el 26 de septiembre!</p>
      </div>
    </div>
  </div>
</section>

<style>
  /* Card-style radio: selected state */
  .rsvp-radio:checked + .rsvp-card {
    border-color: #5f704c;
    background-color: #f6f7f4;
    box-shadow: 0 0 0 1px #5f704c;
  }
  .rsvp-radio:checked + .rsvp-card svg {
    color: #5f704c;
  }
  .rsvp-radio:checked + .rsvp-card span {
    color: #3e4834;
    font-weight: 500;
  }
  .rsvp-radio:focus-visible + .rsvp-card {
    outline: 2px solid #96a67e;
    outline-offset: 2px;
  }
</style>

<script>
  // Smooth expand/collapse attending fields
  const attendingFields = document.getElementById('attending-fields') as HTMLElement;

  document.querySelectorAll('input[name="asistencia"]').forEach((radio) => {
    radio.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      if (!attendingFields) return;

      if (target.value === 'si') {
        attendingFields.style.maxHeight = attendingFields.scrollHeight + 'px';
        attendingFields.style.opacity = '1';
        // After animation, remove max-height cap so content can flex
        attendingFields.addEventListener('transitionend', function handler() {
          if (attendingFields.style.opacity === '1') {
            attendingFields.style.maxHeight = 'none';
          }
          attendingFields.removeEventListener('transitionend', handler);
        });
      } else {
        // Collapse
        attendingFields.style.maxHeight = attendingFields.scrollHeight + 'px';
        attendingFields.offsetHeight; // force reflow
        attendingFields.style.maxHeight = '0';
        attendingFields.style.opacity = '0';
      }
    });
  });

  // Form submit (visual only — replace with Google Forms integration)
  document.getElementById('rsvp-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const isConnected = form.dataset.connected === 'true';

    if (!isConnected) {
      form.style.maxHeight = form.scrollHeight + 'px';
      form.offsetHeight;
      form.style.overflow = 'hidden';
      form.style.transition = 'max-height 0.5s ease, opacity 0.4s ease';
      form.style.maxHeight = '0';
      form.style.opacity = '0';

      setTimeout(() => {
        form.classList.add('hidden');
        const success = document.getElementById('form-success');
        if (success) {
          success.classList.remove('hidden');
          success.style.opacity = '0';
          success.style.transition = 'opacity 0.5s ease';
          requestAnimationFrame(() => { success.style.opacity = '1'; });
        }
      }, 500);
    }
  });
</script>